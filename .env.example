# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=causal_ai_db
POSTGRES_USER=causal_user
POSTGRES_PASSWORD=causal_pass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=causal-ai-token-123
INFLUXDB_ORG=causal-ai
INFLUXDB_BUCKET=sensor_data

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=causal-ai-consumers

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=causal-ai
KEYCLOAK_CLIENT_ID=causal-ai-platform
KEYCLOAK_CLIENT_SECRET=

# Security Configuration
JWT_ALGORITHM=RS256
SESSION_TIMEOUT_MINUTES=30
PASSWORD_MIN_LENGTH=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
